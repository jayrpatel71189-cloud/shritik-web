{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/private-label/layout,_N_T_/private-label/page,_N_T_/private-label"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/private-label/__PAGE__",
    "/private-label",
    "/_index",
    "/_head"
  ]
}