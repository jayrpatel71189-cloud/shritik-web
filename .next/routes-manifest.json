{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/export",
      "regex": "^/export(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/export(?:/)?$"
    },
    {
      "page": "/infrastructure",
      "regex": "^/infrastructure(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/infrastructure(?:/)?$"
    },
    {
      "page": "/private-label",
      "regex": "^/private\\-label(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/private\\-label(?:/)?$"
    },
    {
      "page": "/products",
      "regex": "^/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products(?:/)?$"
    },
    {
      "page": "/products/cashew-kernels",
      "regex": "^/products/cashew\\-kernels(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/cashew\\-kernels(?:/)?$"
    },
    {
      "page": "/products/dehydrated-garlic",
      "regex": "^/products/dehydrated\\-garlic(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/dehydrated\\-garlic(?:/)?$"
    },
    {
      "page": "/products/dehydrated-ginger",
      "regex": "^/products/dehydrated\\-ginger(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/dehydrated\\-ginger(?:/)?$"
    },
    {
      "page": "/products/dehydrated-onion",
      "regex": "^/products/dehydrated\\-onion(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/dehydrated\\-onion(?:/)?$"
    },
    {
      "page": "/quality",
      "regex": "^/quality(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/quality(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}