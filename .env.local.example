# Gmail SMTP credentials for contact form emails
# Use a dedicated Gmail account (not your personal one)
#
# Steps to get GMAIL_APP_PASSWORD:
# 1. Enable 2-Step Verification on the Gmail account
# 2. Go to Google Account > Security > App Passwords
# 3. Generate a password for "Mail" > "Other (custom)" > name it "Shritik Website"
# 4. Copy the 16-character password (no spaces) into GMAIL_APP_PASSWORD below

GMAIL_USER=your-sender@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address that receives contact form submissions
CONTACT_EMAIL=info@shritikenterprises.com
