# Contact Form — Email Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# A long, random secret used to sign form tokens (replay-attack prevention).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTACT_FORM_SECRET=your_long_random_secret_here

# Gmail address used to SEND emails (must be the same account the App Password belongs to)
GMAIL_USER=youraddress@gmail.com

# Gmail App Password (NOT your normal Gmail password).
# Steps to create one:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to Google Account → Security → App Passwords
#   3. Select "Mail" + "Other (custom)" → name it "Shritik Web Contact Form"
#   4. Copy the 16-character password (spaces are fine — Gmail ignores them)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The Gmail address that should RECEIVE contact form submissions
# (can be the same as GMAIL_USER or a different account)
RECIPIENT_EMAIL=info@shritikenterprises.com
