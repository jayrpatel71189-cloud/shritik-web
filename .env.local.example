# Contact Form — Email Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# A long, random secret used to sign form tokens (replay-attack prevention).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTACT_FORM_SECRET=your_long_random_secret_here

# Resend API key — create one at https://resend.com/api-keys
# Scope it to "Sending access" only for your verified domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for outgoing emails.
# Must use a domain you have verified in Resend (e.g. shritikllp.com).
FROM_EMAIL=info@shritikllp.com

# The address that receives contact form submissions.
RECIPIENT_EMAIL=info@shritikllp.com
